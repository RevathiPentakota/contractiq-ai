# ── Application ────────────────────────────────────────────────────────────────
APP_ENV=development
APP_DEBUG=true
APP_VERSION=1.0.0

# ── API ────────────────────────────────────────────────────────────────────────
API_HOST=0.0.0.0
API_PORT=8000

# ── CORS ───────────────────────────────────────────────────────────────────────
# Comma-separated list of allowed origins
CORS_ORIGINS=http://localhost:3000,http://127.0.0.1:3000

# ── Database ───────────────────────────────────────────────────────────────────
DATABASE_URL=postgresql+asyncpg://user:password@localhost:5432/contractiq

# ── Supabase ───────────────────────────────────────────────────────────────────
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# ── LLM / LiteLLM Proxy ───────────────────────────────────────────────────────
LLM_BASE_URL=http://localhost:4000          # LiteLLM Proxy base URL
LLM_API_KEY=your-litellm-api-key
LLM_MODEL=gpt-4o
LLM_TIMEOUT_SECONDS=120
TEMPERATURE=0.2
MAX_TOKENS=4096

# ── Logging ────────────────────────────────────────────────────────────────────
LOG_LEVEL=INFO
